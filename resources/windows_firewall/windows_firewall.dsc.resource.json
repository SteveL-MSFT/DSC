{
    "$schema": "https://aka.ms/dsc/schemas/v3/bundled/resource/manifest.json",
    "type": "Microsoft.Windows/FirewallRule",
    "description": "Manage Windows Firewall rules",
    "tags": [
        "Windows"
    ],
    "version": "0.1.0",
    "get": {
        "executable": "windows_firewall",
        "args": [
            "get",
            {
                "jsonInputArg": "--input",
                "mandatory": true
            }
        ]
    },
    "set": {
        "executable": "windows_firewall",
        "args": [
            "set",
            {
                "jsonInputArg": "--input",
                "mandatory": true
            }
        ],
        "implementsPretest": false,
        "return": "state",
        "requireSecurityContext": "elevated"
    },
    "export": {
        "executable": "windows_firewall",
        "args": [
            "export",
            {
                "jsonInputArg": "--input",
                "mandatory": false
            }
        ]
    },
    "exitCodes": {
        "0": "Success",
        "1": "Invalid arguments",
        "2": "Invalid input",
        "3": "Firewall error"
    },
    "schema": {
        "embedded": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "title": "Windows Firewall Rule",
            "description": "Manage Windows Firewall rules.",
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "title": "Rule name",
                    "description": "The name of the firewall rule."
                },
                "_name": {
                    "type": "string",
                    "title": "Canonical name",
                    "description": "The canonical name of the firewall rule (read-only)."
                },
                "_exist": {
                    "type": "boolean",
                    "title": "Exists",
                    "description": "Whether the firewall rule should exist. Set to false to remove the rule."
                },
                "description": {
                    "type": "string",
                    "title": "Description",
                    "description": "A description of the firewall rule."
                },
                "enabled": {
                    "type": "boolean",
                    "title": "Enabled",
                    "description": "Whether the firewall rule is enabled."
                },
                "direction": {
                    "type": "string",
                    "title": "Direction",
                    "description": "The direction of network traffic the rule applies to.",
                    "enum": [
                        "Inbound",
                        "Outbound"
                    ]
                },
                "action": {
                    "type": "string",
                    "title": "Action",
                    "description": "The action to take when the rule matches traffic.",
                    "enum": [
                        "Allow",
                        "Block"
                    ]
                },
                "protocol": {
                    "type": "string",
                    "title": "Protocol",
                    "description": "The network protocol the rule applies to.",
                    "enum": [
                        "TCP",
                        "UDP",
                        "ICMPv4",
                        "ICMPv6",
                        "Any"
                    ]
                },
                "localPorts": {
                    "type": "string",
                    "title": "Local ports",
                    "description": "The local ports the rule applies to. Use comma-separated values or ranges (e.g., '80,443,8000-9000'). Only valid for TCP and UDP protocols."
                },
                "remotePorts": {
                    "type": "string",
                    "title": "Remote ports",
                    "description": "The remote ports the rule applies to. Use comma-separated values or ranges. Only valid for TCP and UDP protocols."
                },
                "localAddresses": {
                    "type": "string",
                    "title": "Local addresses",
                    "description": "The local addresses the rule applies to. Use comma-separated values, CIDR notation, or ranges."
                },
                "remoteAddresses": {
                    "type": "string",
                    "title": "Remote addresses",
                    "description": "The remote addresses the rule applies to. Use comma-separated values, CIDR notation, or ranges."
                },
                "profiles": {
                    "type": "array",
                    "title": "Profiles",
                    "description": "The network profiles the rule applies to.",
                    "items": {
                        "type": "string",
                        "enum": [
                            "Domain",
                            "Private",
                            "Public"
                        ]
                    }
                },
                "program": {
                    "type": "string",
                    "title": "Program",
                    "description": "The full path to the program the rule applies to."
                }
            },
            "additionalProperties": false
        }
    }
}
